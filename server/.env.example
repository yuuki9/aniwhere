DB_HOST=<db-host>
DB_PORT=25431
DB_NAME=aniwhere
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# Toss mTLS (호스트 /home/ubuntu/mtls/ 에 cert/key 배치, docker-compose 가 동일 경로로 마운트)
# APP_TOSS_MTLS_CERT_PATH=/home/ubuntu/mtls/aniwheretls_public.crt
# APP_TOSS_MTLS_KEY_PATH=/home/ubuntu/mtls/aniwheretls_private.key
# cert 파일 존재 검증만 건너뛸 때 (mTLS는 그대로 적용):
# APP_TOSS_MTLS_SKIP_STARTUP_CHECK=true
# 로컬에서 mTLS 없이 기동할 때 (토스 API 호출은 실패):
# APP_TOSS_MTLS_ENABLED=false
